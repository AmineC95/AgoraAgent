{
  "name": "agoraagentfrontend",
  "version": "0.0.1",
  "description": "AgoraAgentFrontend",
  "productName": "AgoraAgentFrontend",
  "author": "Amine Chioukh <amine.chioukh95@hotmail.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,css,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "quasar dev",
    "build": "quasar build",
    "postinstall": "quasar prepare",
    "generate-api": "npx openapi-typescript http://localhost:5000/openapi/v1.json --output src/api/models.ts"
  },
  "dependencies": {
    "@microsoft/signalr": "^10.0.0",
    "@quasar/extras": "^1.18.0",
    "axios": "^1.16.1",
    "pinia": "^3.0.4",
    "quasar": "^2.19.3",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@intlify/unplugin-vue-i18n": "^11.2.3",
    "@quasar/app-vite": "^2.6.0",
    "@types/node": "^25.9.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite-plugin-checker": "^0.13.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.3.0"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22.12",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1",
    "pnpm": ">= 10.0.0"
  }
}
